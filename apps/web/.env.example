# Privy - auth + embedded wallets (https://dashboard.privy.io)
# When unset, the app falls back to the client-side demo wallet.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Internal agent endpoints and shared server-only credential.
SHIRE_AGENT_CHAT_URL=http://localhost:3010/chat/role-aware-chat-agent
SHIRE_AGENT_INTERNAL_URL=http://localhost:3010
SHIRE_AGENT_SERVICE_TOKEN=replace-with-the-same-long-random-secret-as-agent

# Hosted Postgres connections are server-only. Never add NEXT_PUBLIC_ prefixes.
# Runtime: pooled URL for the application login.
DATABASE_URL=postgresql://APP_USER:PASSWORD@POOLER_HOST/DATABASE?sslmode=require
# Migrations: owner/direct URL. On Neon, use the unpooled connection string.
DIRECT_DATABASE_URL=postgresql://OWNER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require

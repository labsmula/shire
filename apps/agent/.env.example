NODE_ENV=development
PORT=3010

SHIRE_AUTONOMY_MODE=semi-autonomous
SHIRE_LOG_LEVEL=debug
SHIRE_PRETTY_LOGS=true
SHIRE_MODEL_CHEAP=openrouter/openai/gpt-oss-20b:free,openrouter/nex-agi/nex-n2-pro:free
SHIRE_MODEL_BALANCED=openrouter/openai/gpt-oss-20b:free,openrouter/nex-agi/nex-n2-pro:free
SHIRE_MODEL_HEAVY=openrouter/openai/gpt-oss-20b:free,openrouter/nex-agi/nex-n2-pro:free
SHIRE_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
SHIRE_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
SHIRE_EMBEDDING_ENABLED=true
SHIRE_WORKING_MEMORY_ENABLED=false

SHIRE_AGENT_MEMORY_URL=file:./.data/shire-agent-memory.db
SHIRE_AGENT_KNOWLEDGE_URL=file:./.data/shire-agent-knowledge.db
SHIRE_AGENT_KNOWLEDGE_INDEX=shire_context
SHIRE_RAG_TOP_K=5
SHIRE_RAG_MAX_CHARACTERS=8000

OPENROUTER_API_KEY=

NODE_ENV=development
PORT=3010

SHIRE_AUTONOMY_MODE=semi-autonomous
SHIRE_LOG_LEVEL=debug
SHIRE_PRETTY_LOGS=true
SHIRE_MODEL_CHEAP=openrouter/meta-llama/llama-3.3-70b-instruct:free,zai/glm-4.5-air,openai/gpt-4.1-mini
SHIRE_MODEL_BALANCED=zai/glm-4.5-air,openrouter/qwen/qwen3-32b,openai/gpt-4.1-mini
SHIRE_MODEL_HEAVY=openai/gpt-5,zai/glm-4.5
SHIRE_EMBEDDING_MODEL=text-embedding-3-small

SHIRE_AGENT_MEMORY_URL=file:./.data/shire-agent-memory.db
SHIRE_AGENT_KNOWLEDGE_URL=file:./.data/shire-agent-knowledge.db
SHIRE_AGENT_KNOWLEDGE_INDEX=shire-context
SHIRE_RAG_TOP_K=5
SHIRE_RAG_MAX_CHARACTERS=8000

OPENAI_API_KEY=
OPENROUTER_API_KEY=
ZAI_API_KEY=

{
  "name": "@shire/agent",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test test/index.ts",
    "start": "node --env-file-if-exists=.env --import tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json",
    "job:cv-parse": "node --import tsx src/jobs/run-cv-parse.ts",
    "job:job-matching": "node --import tsx src/jobs/run-job-matching.ts",
    "job:knowledge-sync": "node --import tsx src/jobs/run-knowledge-sync.ts",
    "job:talent-matching": "node --import tsx src/jobs/run-talent-matching.ts",
    "job:onchain-sync": "node --import tsx src/jobs/run-onchain-sync.ts",
    "job:dispute-summary": "node --import tsx src/jobs/run-dispute-summary.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.69",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@mastra/ai-sdk": "^1.4.4",
    "@mastra/core": "latest",
    "@mastra/express": "^1.3.29",
    "@mastra/libsql": "^1.12.1",
    "@mastra/memory": "^1.20.2",
    "@mastra/rag": "^2.2.1",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "ai": "^6.0.201",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "latest",
    "mastra": "latest",
    "pino-pretty": "^13.1.3",
    "tsx": "latest",
    "typescript": "latest"
  }
}
